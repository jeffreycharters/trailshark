{
	"name": "trailshark",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "dotenv -e .env.dev vite dev -- --host",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "rm prisma/test.db && npm run pushdb:test && dotenv -e .env.test vitest",
		"test:unit-nodb": "npm run pushdb:test && dotenv -e .env.test vitest",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"pushdb:test": "dotenv -e .env.test prisma db push",
		"pushdb:dev": "dotenv -e .env.dev prisma db push",
		"seedb:dev": "dotenv -e .env.dev prisma studio",
		"seedb:test": "dotenv -e .env.test prisma studio"
	},
	"devDependencies": {
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-auto": "next",
		"@sveltejs/kit": "next",
		"@types/jsonwebtoken": "^9.0.0",
		"@types/nodemailer": "^6.4.7",
		"@typescript-eslint/eslint-plugin": "^5.46.1",
		"@typescript-eslint/parser": "^5.46.1",
		"autoprefixer": "^10.4.13",
		"eslint": "^8.29.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte3": "^4.0.0",
		"postcss": "^8.4.20",
		"prettier": "^2.8.1",
		"prettier-plugin-svelte": "^2.9.0",
		"prisma": "^4.7.1",
		"svelte": "^3.55.0",
		"svelte-check": "^2.10.2",
		"svelte-preprocess": "^5.0.0",
		"tailwindcss": "^3.2.4",
		"tslib": "^2.4.1",
		"typescript": "^4.9.4",
		"vite": "^4.0.1",
		"vitest": "^0.25.8"
	},
	"type": "module",
	"dependencies": {
		"@lucia-auth/adapter-prisma": "^0.1.4",
		"@lucia-auth/sveltekit": "^0.5.0",
		"@prisma/client": "^4.7.1",
		"daisyui": "^2.45.0",
		"dotenv-cli": "^6.0.0",
		"googleapis": "^110.0.0",
		"jsonwebtoken": "^9.0.0",
		"lucia-auth": "^0.3.1",
		"nodemailer": "^6.8.0",
		"slugify": "^1.6.5"
	}
}
